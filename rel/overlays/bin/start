#!/bin/sh
set -eu

cd -P -- "$(dirname -- "$0")"

if [ -n "${ADMIN_EMAIL:-}" ] && [ -n "${ADMIN_PASSWORD:-}" ]; then
  echo "Ensuring admin account..."
  ./spectabas eval "Spectabas.Release.create_admin(\"$ADMIN_EMAIL\", \"$ADMIN_PASSWORD\")"
fi

echo "Starting server..."
PHX_SERVER=true exec ./spectabas start
