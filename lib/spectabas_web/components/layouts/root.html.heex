<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <.live_title default="Spectabas — Privacy-First Analytics" suffix=" · Spectabas">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="bg-white antialiased">
    <nav
      class="bg-white border-b border-gray-200 relative z-50"
      role="navigation"
      aria-label="Main navigation"
    >
      <div class="px-4 sm:px-6">
        <div class="flex justify-between h-12 sm:h-14">
          <%!-- Left: logo + nav links (hidden on mobile) --%>
          <div class="flex items-center gap-4 sm:gap-6">
            <a
              href="/"
              class="flex items-center gap-1.5 sm:gap-2 shrink-0"
              aria-label="Spectabas home"
            >
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="22"
                height="22"
                viewBox="0 0 32 32"
                aria-hidden="true"
                class="sm:w-[26px] sm:h-[26px]"
              >
                <rect width="32" height="32" rx="6" ry="6" fill="#6366f1" />
                <g transform="translate(5, 5) scale(0.043)">
                  <path
                    fill="white"
                    d="M496 384H64V80c0-8.84-7.16-16-16-16H16C7.16 64 0 71.16 0 80v336c0 17.67 14.33 32 32 32h464c8.84 0 16-7.16 16-16v-32c0-8.84-7.16-16-16-16zM464 96H345.94c-21.38 0-32.09 25.85-16.97 40.97l32.4 32.4L288 242.75l-73.37-73.37c-12.5-12.5-32.76-12.5-45.25 0l-68.69 68.69c-6.25 6.25-6.25 16.38 0 22.63l22.62 22.62c6.25 6.25 16.38 6.25 22.63 0L192 237.25l73.37 73.37c12.5 12.5 32.76 12.5 45.25 0l96-96 32.4 32.4c15.12 15.12 40.97 4.41 40.97-16.97V112c.01-8.84-7.15-16-15.99-16z"
                  />
                </g>
              </svg>
              <span class="text-sm sm:text-base font-bold text-gray-900">Spectabas</span>
            </a>
            <%!-- Desktop nav links --%>
            <%= if assigns[:current_scope] && @current_scope.user do %>
              <div class="hidden sm:flex items-center gap-4">
                <a
                  href="/dashboard"
                  class="text-sm text-gray-600 hover:text-indigo-600 font-medium"
                >
                  Dashboard
                </a>
                <a href="/docs" class="text-sm text-gray-600 hover:text-indigo-600 font-medium">
                  Docs
                </a>
                <%= if @current_scope.user.role in [:superadmin, :admin] do %>
                  <a href="/admin" class="text-sm text-gray-600 hover:text-indigo-600 font-medium">
                    Admin
                  </a>
                <% end %>
              </div>
            <% end %>
          </div>

          <%!-- Right: user menu --%>
          <div class="flex items-center gap-2 sm:gap-4 text-xs sm:text-sm">
            <%= if assigns[:current_scope] && @current_scope.user do %>
              <span class="text-gray-500 hidden md:inline">{@current_scope.user.email}</span>
              <a
                href="/users/settings"
                class="hidden sm:inline text-gray-600 hover:text-indigo-600 font-medium"
              >
                Account
              </a>
              <.link
                href={~p"/users/log-out"}
                method="delete"
                class="hidden sm:inline text-gray-600 hover:text-indigo-600 font-medium"
              >
                Log out
              </.link>
              <%!-- Mobile: icon links with 44px touch targets --%>
              <div class="flex sm:hidden items-center gap-1">
                <a
                  href="/dashboard"
                  class="p-2.5 text-gray-500 hover:text-indigo-600"
                  title="Dashboard"
                  aria-label="Dashboard"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"
                    >
                    </path>
                  </svg>
                </a>
                <a
                  href="/docs"
                  class="p-2.5 text-gray-500 hover:text-indigo-600"
                  title="Docs"
                  aria-label="Documentation"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"
                    >
                    </path>
                  </svg>
                </a>
                <a
                  href="/users/settings"
                  class="p-2.5 text-gray-500 hover:text-indigo-600"
                  title="Account"
                  aria-label="Account settings"
                >
                  <svg
                    class="w-5 h-5"
                    fill="none"
                    stroke="currentColor"
                    viewBox="0 0 24 24"
                    aria-hidden="true"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"
                    >
                    </path>
                  </svg>
                </a>
              </div>
            <% else %>
              <a
                href="/users/log-in"
                class="inline-flex items-center px-3 sm:px-4 py-1.5 text-xs sm:text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500"
              >
                Sign in
              </a>
            <% end %>
          </div>
        </div>
      </div>
    </nav>
    {@inner_content}
  </body>
</html>
