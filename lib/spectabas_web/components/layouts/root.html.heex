<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <.live_title default="Spectabas — Privacy-First Analytics" suffix=" · Spectabas">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="bg-white antialiased">
    <nav class="bg-slate-900 relative z-50">
      <div class="px-4 sm:px-6">
        <div class="flex justify-between h-11">
          <div class="flex items-center gap-4">
            <a href="/" class="flex items-center gap-1.5">
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 32 32">
                <rect width="32" height="32" rx="6" ry="6" fill="#6366f1" />
                <g transform="translate(5, 5) scale(0.043)">
                  <path
                    fill="white"
                    d="M496 384H64V80c0-8.84-7.16-16-16-16H16C7.16 64 0 71.16 0 80v336c0 17.67 14.33 32 32 32h464c8.84 0 16-7.16 16-16v-32c0-8.84-7.16-16-16-16zM464 96H345.94c-21.38 0-32.09 25.85-16.97 40.97l32.4 32.4L288 242.75l-73.37-73.37c-12.5-12.5-32.76-12.5-45.25 0l-68.69 68.69c-6.25 6.25-6.25 16.38 0 22.63l22.62 22.62c6.25 6.25 16.38 6.25 22.63 0L192 237.25l73.37 73.37c12.5 12.5 32.76 12.5 45.25 0l96-96 32.4 32.4c15.12 15.12 40.97 4.41 40.97-16.97V112c.01-8.84-7.15-16-15.99-16z"
                  />
                </g>
              </svg>
              <span class="text-sm font-bold text-white">Spectabas</span>
            </a>
            <%= if assigns[:current_scope] && @current_scope.user do %>
              <a href="/dashboard" class="text-xs text-slate-400 hover:text-white font-medium">
                Dashboard
              </a>
              <%= if @current_scope.user.role in [:superadmin, :admin] do %>
                <a href="/admin" class="text-xs text-slate-400 hover:text-white font-medium">
                  Admin
                </a>
              <% end %>
            <% end %>
          </div>
          <div class="flex items-center gap-3 text-xs">
            <%= if assigns[:current_scope] && @current_scope.user do %>
              <span class="text-slate-500 hidden sm:inline">{@current_scope.user.email}</span>
              <a href="/users/settings" class="text-slate-400 hover:text-white">Account</a>
              <.link
                href={~p"/users/log-out"}
                method="delete"
                class="text-slate-400 hover:text-white"
              >
                Log out
              </.link>
            <% else %>
              <a
                href="/users/log-in"
                class="inline-flex items-center px-3 py-1 text-xs font-medium rounded text-white bg-indigo-600 hover:bg-indigo-700"
              >
                Sign in
              </a>
            <% end %>
          </div>
        </div>
      </div>
    </nav>
    {@inner_content}
  </body>
</html>
