<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="Spectabas — Privacy-First Analytics" suffix=" · Spectabas">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}>
    </script>
  </head>
  <body class="bg-white antialiased">
    <nav class="bg-white border-b border-gray-200">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex justify-between h-16">
          <div class="flex items-center">
            <.link href={~p"/"} class="text-xl font-bold text-indigo-600">
              Spectabas
            </.link>
          </div>
          <div class="flex items-center gap-4 text-sm">
            <%= if assigns[:current_scope] && @current_scope.user do %>
              <span class="text-gray-600">{@current_scope.user.email}</span>
              <.link
                href={~p"/dashboard"}
                class="text-gray-700 hover:text-indigo-600 font-medium"
              >
                Dashboard
              </.link>
              <.link
                href={~p"/users/settings"}
                class="text-gray-700 hover:text-indigo-600"
              >
                Settings
              </.link>
              <.link
                href={~p"/users/log-out"}
                method="delete"
                class="text-gray-700 hover:text-indigo-600"
              >
                Log out
              </.link>
            <% else %>
              <.link
                href={~p"/users/log-in"}
                class="inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-lg text-white bg-indigo-600 hover:bg-indigo-700 transition"
              >
                Sign in
              </.link>
            <% end %>
          </div>
        </div>
      </div>
    </nav>
    {@inner_content}
  </body>
</html>
